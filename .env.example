# Copy to .env and adjust. Do not commit .env.
# Only VITE_* variables are exposed to the frontend app.

# Backend API URL
VITE_API_URL=https://buildingsystem-backend.onrender.com/api

# Optional (if your app uses them)
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_MONGODB_URI=

# development | production (Vite sets this in build)
NODE_ENV=development
